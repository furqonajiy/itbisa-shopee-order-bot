# Template for local testing only.
# Copy this to .env and fill in real values. Never commit .env to git.
#
# In production (GitHub Actions), these are set as repository Secrets instead.
#
# Note: SHOPEE_ACCESS_TOKEN is NOT listed here. It is managed automatically
# in data/shopee_tokens.json (see shopee_auth.py). You only need to bootstrap
# the tokens file once, after authorizing the app in Shopee Open Platform.

SHOPEE_PARTNER_ID=123456
SHOPEE_PARTNER_KEY=your_partner_key_here
SHOPEE_SHOP_ID=987654

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789

# Set to "true" to use canned fake orders instead of calling Shopee.
# Useful for local testing when sandbox access is not available.
# Leave this empty or "false" in production.
USE_FAKE_SHOPEE=false
